{
  "workbench.sideBar.location": "right",
  "workbench.activityBar.location": "top",
  "editor.wordWrap": "on",
  "window.density.editorTabHeight": "compact",
  "editor.fontFamily": "Fira Code,OperatorMonoSSmLig Nerd Font,'Droid Sans Mono', 'monospace', monospace",
  "workbench.iconTheme": "vscode-icons",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[astro]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "git.autofetch": true,
  "window.zoomLevel": 1.3,
  "editor.fontSize": 15,
  "editor.formatOnSave": true,
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.fontFamily": "MesloLGS NF",
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.experimental.preferTreeSitter.typescript": true,
  "reactSnippets.settings.importReactOnTop": false,
  "reactSnippets.settings.prettierEnabled": true,
  "database-client.autoSync": true,
  "cSpell.userWords": [
    "alpinejs",
    "bigserial",
    "bullmq",
    "bunx",
    "Caddyfile",
    "caddyserver",
    "Choicebox",
    "colour",
    "COOLDOWN",
    "Eren",
    "expomohx",
    "hono",
    "ianvs",
    "ilike",
    "Kysely",
    "libsql",
    "Liviya",
    "Millis",
    "mohammedsh",
    "mohx",
    "mohxmd",
    "MULTIPOLYGON",
    "nativewind",
    "neondatabase",
    "nextjs",
    "noconfirm",
    "nums",
    "Nuqs",
    "Oriyx",
    "orpc",
    "oryft",
    "pacman",
    "Paise",
    "pincode",
    "pkill",
    "postgis",
    "presign",
    "Pressable",
    "revolva",
    "runserver",
    "Sakura",
    "SETEX",
    "shadcn",
    "Shajahan",
    "shiki",
    "shikijs",
    "sonner",
    "springify",
    "srid",
    "sslmode",
    "TIMESTAMPTZ",
    "treeified",
    "treeify",
    "turbopack",
    "Turborepo",
    "TURSO",
    "Unban",
    "uniwind",
    "upgrader",
    "upvote",
    "varchar",
    "vaul",
    "Wishlisted",
    "Zoomable",
  ],
  "[sql]": {
    "editor.defaultFormatter": "inferrinizzard.prettier-sql-vscode",
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
  },
  "git.blame.statusBarItem.enabled": false,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "typescript": false,
    "shellscript": false,
    "dockercompose": false,
    "typescriptreact": false,
    "jsonc": false,
    "rust": true
  },
  "search.exclude": {
    ".prettierrc": true,
    ".next/**": true,
    "node_modules/**": true,
  },
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "ngClass",
    "class:list",
    ".*ClassName",
    ".*Class",
  ],
  "git.suggestSmartCommit": false,
  "workbench.editor.empty.hint": "hidden",
  "chat.agent.enabled": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "security.workspace.trust.untrustedFiles": "open",
  "github.copilot.nextEditSuggestions.enabled": false,
  "redhat.telemetry.enabled": true,
  "svelte.enable-ts-plugin": true,
  "kotlin.languageServer.enabled": false,
  "kotlin.debugAdapter.enabled": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "claudeCode.preferredLocation": "panel",
  "prettier.printWidth": 100,
  "editor.tabSize": 2,
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true,
  },
  "workbench.colorTheme": "Atom Just Black",
  "window.customTitleBarVisibility": "never",
  "window.titleBarStyle": "native",
  "geminicodeassist.project": "possible-pact-fshbt",
  "diffEditor.codeLens": true
}
