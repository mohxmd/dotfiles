#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TASK_DIR="$ROOT_DIR/run.d"

usage() {
  cat <<'EOF'
Usage:
  ./run <task> [args...]
  ./run --list

Examples:
  ./run dev
  ./run firewall
  ./run dotfiles auto
EOF
}

list_tasks() {
  if [[ ! -d "$TASK_DIR" ]]; then
    return 0
  fi

  find "$TASK_DIR" -maxdepth 1 -type f -executable -printf "%f\n" | sort
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  -l|--list)
    list_tasks
    exit 0
    ;;
esac

task="$1"
shift || true
task_path="$TASK_DIR/$task"

if [[ ! -x "$task_path" ]]; then
  echo "Unknown task: $task" >&2
  echo "Available tasks:" >&2
  list_tasks | sed 's/^/  - /' >&2
  exit 1
fi

exec "$task_path" "$@"
