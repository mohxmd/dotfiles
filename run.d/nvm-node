#!/usr/bin/env bash
set -euo pipefail

command -v sudo >/dev/null 2>&1 || { echo "sudo is required." >&2; exit 1; }
command -v pacman >/dev/null 2>&1 || { echo "pacman is required." >&2; exit 1; }

NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
export NVM_DIR

if [[ ! -s /usr/share/nvm/init-nvm.sh && ! -s /usr/share/nvm/nvm.sh && ! -s "$NVM_DIR/nvm.sh" ]]; then
  echo "[nvm-node] Installing nvm from Arch repositories"
  sudo pacman -S --needed nvm
fi

if [[ -s /usr/share/nvm/init-nvm.sh ]]; then
  # Arch package-provided init script.
  # shellcheck disable=SC1091
  source /usr/share/nvm/init-nvm.sh
elif [[ -s /usr/share/nvm/nvm.sh ]]; then
  # shellcheck disable=SC1091
  source /usr/share/nvm/nvm.sh
elif [[ -s "$NVM_DIR/nvm.sh" ]]; then
  # shellcheck disable=SC1090
  source "$NVM_DIR/nvm.sh"
else
  echo "nvm init script not found after install." >&2
  exit 1
fi

node_version="${NODE_VERSION:-lts/*}"

echo "[nvm-node] Installing Node ($node_version)"
nvm install "$node_version"
nvm use "$node_version"
nvm alias default "$node_version"

if command -v corepack >/dev/null 2>&1; then
  corepack enable || true
fi

echo "[nvm-node] Versions"
node --version || true
npm --version || true
nvm --version || true
